# ─────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente de produção — <dominio>
#
# Ficheiro único e partilhado por TODAS as apps (auth, api, notifications,
# worker, cron, web) — o ecosystem.config.js carrega-o da raiz do repo
# consoante o `--env` passado ao PM2:
#   .env.production   → pm2 start ecosystem.config.js --env production
#   .env.qa           → pm2 start ecosystem.config.js --env qa
#
# Copiar para a raiz como .env.production (ou .env.qa) e preencher os valores
# marcados "PREENCHER". NODE_ENV e PORT por processo já são definidos pelo
# ecosystem.config.js — não precisas de os declarar aqui.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de dados / infraestrutura (todas as apps) ────────────────────────────
DATABASE_URL="postgres://appuser:PREENCHER@localhost:5432/appdb?schema=public"
REDIS_HOST="localhost"
REDIS_PORT="6379"
# REDIS_PASSWORD=                          # recomendado em produção — ver infra/redis.md
MONGO_URI="mongodb://appuser:PREENCHER@127.0.0.1:27017/appdb?authSource=admin"

# ── CORS (auth, api, notifications, worker, cron) ─────────────────────────────
CORS_ORIGIN="https://<dominio>"

# ── Better Auth (apps/auth) ────────────────────────────────────────────────────
BETTER_AUTH_SECRET="PREENCHER"            # gerar com: openssl rand -hex 32
BETTER_AUTH_URL="https://<dominio>/api/auth"
ADMIN_EMAIL="PREENCHER"
ADMIN_PASSWORD="PREENCHER"
# GOOGLE_CLIENT_ID=                       # opcional — login com Google
# GOOGLE_CLIENT_SECRET=

# ── Mail (apps/worker) ──────────────────────────────────────────────────────────
BREVO_API_KEY="PREENCHER"
FROM_EMAIL="PREENCHER"
FROM_NAME="PREENCHER"
# DEV_EMAIL=                               # opcional — redireciona todos os emails (qa)

# ── Observabilidade (todas as apps, opcional) ─────────────────────────────────
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0
# METRICS_TOKEN=                           # bearer token para /metrics; vazio = acesso aberto (ver infra/monitoring.md)

# ── Web (apps/web, Next.js) ────────────────────────────────────────────────────
# URLs internas — o processo Next corre na mesma VPS que auth/api, usar loopback.
AUTH_API_URL="http://127.0.0.1:3000"
API_URL="http://127.0.0.1:3100"
NEXT_PUBLIC_AUTH_API_URL="https://<dominio>"
# NEXT_PUBLIC_STORAGE_URL=                 # opcional — URL pública de storage, se aplicável
# NEXT_PUBLIC_API_URL=                     # opcional — fallback se NEXT_PUBLIC_STORAGE_URL vazio
NEXT_PUBLIC_BASE_PATH=                     # vazio = raiz do domínio; ex "/admin" para subpath (ver nginx/app.conf)
BACKEND_PROTOCOL="https"
BACKEND_HOST="<dominio>"

# ─────────────────────────────────────────────────────────────────────────────
# Fora deste ficheiro — variável de shell, não vai para .env.production:
#   NODE_APP_INSTANCES=4   (opcional — nº de instâncias cluster para auth/api/web;
#                            default 2. Exportar antes de `pm2 start`.)
# ─────────────────────────────────────────────────────────────────────────────
