      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "prisma": "^7.5.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@repo/shared-types": "workspace:*",
    "pg": "^8.20.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16"
  }
