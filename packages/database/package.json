{
  "name": "@repo/database",
  "private": true,
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "dev": "tsc --watch"
  },
  "exports": {
    ".": {
